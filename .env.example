# Expo public variables are embedded in the mobile app bundle.
# For production apps, do not put API passwords, database URLs, or private keys here.

# Public translation gateway origin used by the mobile client.
EXPO_PUBLIC_BASE_URL=
EXPO_PUBLIC_KEY=

# Public PDF.js assets used by the hidden PDF text extractor.
EXPO_PUBLIC_PDFJS_URL=https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js
EXPO_PUBLIC_PDFJS_WORKER_URL=https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js
